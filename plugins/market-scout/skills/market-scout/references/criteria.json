        "performance": {"cpu_score": 0.24, "gpu_score": 0.22, "ram_gb": 0.12, "expert_rating": 0.14, "display_quality": 0.12, "storage_gb": 0.08, "build_quality": 0.08},
        "value":       {"price_usd": 0.32, "expert_rating": 0.20, "cpu_score": 0.14, "battery_hours": 0.12, "ram_gb": 0.10, "display_quality": 0.07, "storage_gb": 0.05},
        "portable":    {"battery_hours": 0.24, "weight_kg": 0.22, "expert_rating": 0.16, "display_quality": 0.12, "build_quality": 0.10, "cpu_score": 0.10, "price_usd": 0.06}
