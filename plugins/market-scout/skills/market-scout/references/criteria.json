        "display_quality": {"label": "Display quality", "unit": "0-10", "direction": "higher"},
        "update_years":    {"label": "OS/security support", "unit": "years", "direction": "higher"},
        "price_usd":       {"label": "Street price", "unit": "USD", "direction": "lower", "is_price": true}
      },
      "profiles": {
        "default":  {"expert_rating": 0.22, "camera_score": 0.18, "cpu_score": 0.14, "battery_hours": 0.14, "display_quality": 0.12, "price_usd": 0.12, "update_years": 0.08},
        "camera":   {"camera_score": 0.34, "expert_rating": 0.20, "display_quality": 0.16, "cpu_score": 0.12, "battery_hours": 0.10, "update_years": 0.08},
        "value":    {"price_usd": 0.34, "expert_rating": 0.22, "battery_hours": 0.16, "cpu_score": 0.12, "camera_score": 0.10, "update_years": 0.06},
        "battery":  {"battery_hours": 0.34, "expert_rating": 0.20, "cpu_score": 0.14, "display_quality": 0.12, "price_usd": 0.12, "camera_score": 0.08}
