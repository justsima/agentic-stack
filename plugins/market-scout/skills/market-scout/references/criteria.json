        "weight_kg":         {"label": "Weight", "unit": "kg", "direction": "lower"},
        "build_quality":     {"label": "Build / keyboard", "unit": "0-10", "direction": "higher"},
        "price_usd":         {"label": "Street price", "unit": "USD", "direction": "lower", "is_price": true}
