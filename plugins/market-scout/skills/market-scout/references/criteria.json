    "_generic": {
      "label": "Generic product",
      "notes": "Fallback for any category not yet modeled. The orchestrator should attach metrics it can find; price_usd + expert_rating are the minimum viable set. Prefer adding a dedicated category over leaning on this.",
      "criteria": {
        "expert_rating": {"label": "Expert review consensus", "unit": "/10", "direction": "higher"},
        "feature_score": {"label": "Feature completeness", "unit": "0-10", "direction": "higher"},
        "reliability":   {"label": "Reliability / owner satisfaction", "unit": "0-10", "direction": "higher"},
        "price_usd":     {"label": "Street price", "unit": "USD", "direction": "lower", "is_price": true}
      },
      "profiles": {
        "default": {"expert_rating": 0.34, "feature_score": 0.24, "reliability": 0.22, "price_usd": 0.20},
        "value":   {"price_usd": 0.40, "expert_rating": 0.28, "reliability": 0.20, "feature_score": 0.12}
      }
    }
  }
}
